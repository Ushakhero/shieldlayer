<!-- PAYMENT MODAL -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-head">
      <div>
        <div class="modal-title" id="modal-title">Get Started</div>
      </div>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-plan-tag" id="modal-tag">GoldenShield AI · Business</div>
    <div class="form-row"><label>Full name</label><input type="text" id="p-name" placeholder="Your full name"></div>
    <div class="form-row"><label>Email</label><input type="email" id="p-email" placeholder="you@company.com"></div>
    <div class="form-row"><label>Organization</label><input type="text" id="p-org" placeholder="Company name"></div>
    <div class="form-row"><label>Currency</label>
      <select id="p-currency" onchange="updateAmt()">
        <option value="NGN">Nigerian Naira (₦)</option>
        <option value="USD">US Dollar ($)</option>
        <option value="GHS">Ghana Cedi (GH₵)</option>
        <option value="KES">Kenyan Shilling (KSh)</option>
      </select>
    </div>
    <div class="price-preview">
      <div class="preview-label" id="p-label">Monthly subscription</div>
      <div class="preview-amount" id="p-amount">₦73,500</div>
    </div>
    <button class="btn-pay btn-pay-gold" id="p-btn" onclick="pay()">🔒 Pay with Paystack</button>
    <div class="pay-note">Secured by Paystack · SSL encrypted · Cancel anytime</div>
  </div>
</div>

<script src="https://js.paystack.co/v1/inline.js"></script>
<script>
let cProduct='',cPlan='',cUSD=0,cNGN=0;
const rates={NGN:1500,GHS:15,KES:130};
const syms={NGN:'₦',USD:'$',GHS:'GH₵',KES:'KSh'};
function switchTab(t,btn){
  ['goldenshield','guardshield'].forEach(id=>{
    document.getElementById('tab-'+id).style.display=id===t?'grid':'none';
  });
  document.querySelectorAll('.price-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}
function openModal(product,plan,usd,ngn){
  cProduct=product;cPlan=plan;cUSD=parseFloat(usd);cNGN=parseFloat(ngn);
  const pName=product==='goldenshield'?'GoldenShield AI':'GuardShield';
  const isGold=product==='goldenshield';
  document.getElementById('modal-title').textContent=plan==='Starter'&&usd==='0'?'Create free account':'Complete purchase';
  document.getElementById('modal-tag').textContent=pName+' · '+plan;
  document.getElementById('modal-tag').className='modal-plan-tag '+(isGold?'tag-gold':'tag-teal');
  document.getElementById('p-amount').className='preview-amount '+(isGold?'':'teal');
  document.getElementById('p-btn').className='btn-pay '+(isGold?'btn-pay-gold':'btn-pay-teal');
  updateAmt();
  document.getElementById('modal').classList.add('open');
}
function updateAmt(){
  const c=document.getElementById('p-currency').value;
  if(cUSD===0){document.getElementById('p-amount').textContent='FREE';document.getElementById('p-label').textContent='No payment required';return;}
  let a=c==='USD'?cUSD:c==='NGN'?cNGN:Math.round(cUSD*rates[c]);
  document.getElementById('p-amount').textContent=syms[c]+a.toLocaleString();
  document.getElementById('p-label').textContent='Monthly subscription';
}
function closeModal(){document.getElementById('modal').classList.remove('open');}
function pay(){
  const name=document.getElementById('p-name').value.trim();
  const email=document.getElementById('p-email').value.trim();
  const org=document.getElementById('p-org').value.trim();
  const c=document.getElementById('p-currency').value;
  if(!name||!email){alert('Please enter name and email.');return;}
  if(!email.includes('@')){alert('Invalid email.');return;}
  if(cUSD===0){alert('Welcome to ShieldLayer! Check '+email+' for your free account.');closeModal();return;}
  let kobo=c==='NGN'?cNGN*100:c==='USD'?cUSD*100:Math.round(cUSD*rates[c])*100;
  const pName=cProduct==='goldenshield'?'GoldenShield AI':'GuardShield';
  const handler=PaystackPop.setup({
    key:'pk_test_YOUR_PAYSTACK_PUBLIC_KEY_HERE',
    email,amount:kobo,
    currency:c==='USD'?'USD':c==='GHS'?'GHS':c==='KES'?'KES':'NGN',
    ref:'SL_'+Date.now(),
    metadata:{custom_fields:[{display_name:'Name',variable_name:'name',value:name},{display_name:'Org',variable_name:'org',value:org},{display_name:'Product',variable_name:'product',value:pName},{display_name:'Plan',variable_name:'plan',value:cPlan}]},
    callback:r=>{closeModal();alert('✅ Payment successful!\nRef: '+r.reference+'\n\nWelcome to '+pName+' '+cPlan+'!\nCheck '+email+' for your account.');},
    onClose:()=>{}
  });
  handler.openIframe();
}
</script>
</body>
</html>
